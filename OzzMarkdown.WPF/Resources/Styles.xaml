<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <Style x:Key="FileSizeCellStyleLight" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#484848"/>
        <Setter Property="Background" Value="{Binding FileSizeInBytes, Converter={StaticResource FileSizeToLightBG}}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="#000000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PackingModeCellStyleLight" TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#484848"/>
        <Setter Property="Background" Value="{Binding PackingMode, Converter={StaticResource PackingModeToColor}}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="#000000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TextBox Style: Disabled when bound to null, with validation error display -->
    <Style x:Key="DisabledWhenNullTextBoxStyle" TargetType="TextBox">
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Validation.ErrorTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <StackPanel>
                        <AdornedElementPlaceholder x:Name="placeholder"/>
                        <TextBlock Text="{Binding ElementName=placeholder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}"
                                   MaxWidth="{Binding ElementName=placeholder, Path=ActualWidth}"
                                   Foreground="#d80000" FontSize="11" Margin="0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ToolTipService.Placement" Value="Bottom"/>
        <Setter Property="ToolTipService.VerticalOffset" Value="5"/>
        <Setter Property="ToolTipService.ShowDuration" Value="10"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="Margin" Value="0,0,0,32"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="#d80000"/>
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
            </Trigger>
            <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                <Setter Property="IsEnabled" Value="False"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBox Style: with validation error display -->
    <Style x:Key="ValidationComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Validation.ErrorTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <StackPanel>
                        <AdornedElementPlaceholder x:Name="placeholder"/>
                        <TextBlock Text="{Binding ElementName=placeholder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}"
                                   MaxWidth="{Binding ElementName=placeholder, Path=ActualWidth}"
                                   Foreground="#d80000" FontSize="11" Margin="0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ToolTipService.Placement" Value="Bottom"/>
        <Setter Property="ToolTipService.VerticalOffset" Value="5"/>
        <Setter Property="ToolTipService.ShowDuration" Value="10"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="Margin" Value="0,0,0,32"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="#d80000"/>
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TextBox Style: validation error display only -->
    <Style x:Key="ValidationTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="24"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Validation.ErrorTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <StackPanel>
                        <AdornedElementPlaceholder x:Name="placeholder"/>
                        <TextBlock Text="{Binding ElementName=placeholder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}"
                                   MaxWidth="{Binding ElementName=placeholder, Path=ActualWidth}"
                                   Foreground="#d80000" FontSize="11" Margin="0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ToolTipService.Placement" Value="Bottom"/>
        <Setter Property="ToolTipService.VerticalOffset" Value="5"/>
        <Setter Property="ToolTipService.ShowDuration" Value="10"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="Margin" Value="0,0,0,32"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="#d80000"/>
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TextBox Style: multi-line validation error display only -->
    <Style x:Key="ValidationMutliLineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ValidationTextBoxStyle}">
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <!-- TextBox Style: read-only display only -->
    <Style x:Key="ReadOnlyTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="24"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Background" Value="#EDEDED"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- TextBlock Style: right-aligned display only -->
    <Style x:Key="RightAlignedTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="4,2,8,0"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <!-- TextBlock Style: mimics read-only display only -->
    <Style x:Key="ReadOnlyTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Background" Value="#EDEDED"/>
    </Style>


    <Style x:Key="StatusTextBlockStyle" TargetType="TextBlock">
        <Style.Triggers>
            <Trigger Property="Text" Value="New">
                <Setter Property="Foreground" Value="Green"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Trigger>
            <Trigger Property="Text" Value="Modified">
                <Setter Property="Foreground" Value="OrangeRed"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Trigger>
            <Trigger Property="Text" Value="Deleted">
                <Setter Property="Foreground" Value="Gray"/>
                <Setter Property="FontStyle" Value="Italic"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Button Style: toolbar icon button 22x18 -->
    <Style x:Key="IconButtonStyle-22x18" TargetType="Button">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <!-- Button Style: toolbar icon button 28x24 -->
    <Style x:Key="IconButtonStyle-28x24" TargetType="Button">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Margin" Value="0,1,4,1"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>


    <Style x:Key="IconButtonStyle-38x24" TargetType="Button" BasedOn="{StaticResource IconButtonStyle-28x24}">
        <Setter Property="Width" Value="38"/>
    </Style>

</ResourceDictionary>